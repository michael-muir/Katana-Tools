                    </stringarray_parameter>
                    <string_parameter name="type" value="StringAttr"/>
                    <string_parameter name="__hints" persistant="false" value="{&apos;default&apos;: &apos;,&apos;, &apos;help&apos;: &apos;List of extra parameters that will be displayed in the Lighting Tools UI when a light is selected, provided the parameters are present in the light.\n&lt;br /&gt;\n&lt;br /&gt;\nThe parameters will be appended after the default parameters (\n&lt;b&gt;Intensity&lt;/b&gt;\n,\n&lt;b&gt;Exposure&lt;/b&gt;\nand\n&lt;b&gt;Color&lt;/b&gt;\n).\n&lt;br /&gt;\n&lt;br /&gt;\nEach entry is compounded of two strings:\n&lt;br /&gt;\n&lt;ul&gt;\n    &lt;li&gt;\n        parameter path (e.g.\n        &lt;code&gt;prmanLightParams.intensity&lt;/code&gt;\n        )\n    &lt;/li&gt;\n    &lt;li&gt;\n        label\n        &lt;em&gt;(optional)&lt;/em&gt;\n    &lt;/li&gt;\n&lt;/ul&gt;\n&lt;br /&gt;\nIf the label is not provided, the parameter&amp;apos;s original label will be used.&apos;, &apos;isDynamicArray&apos;: &apos;1&apos;, &apos;name&apos;: &apos;parameters&apos;, &apos;tupleSize&apos;: &apos;2&apos;, &apos;widget&apos;: &apos;dynamicArray&apos;}"/>
                  </group_parameter>
                  <group_parameter name="hideHandle">
                    <number_parameter name="enable" value="0"/>
                    <number_parameter name="value" value="0"/>
                    <number_parameter name="default" value="0"/>
                    <string_parameter name="type" value="IntAttr"/>
                    <string_parameter name="__hints" persistant="false" value="{&apos;default&apos;: &apos;0&apos;, &apos;help&apos;: &apos;Determines whether the center of interest arrow handles will be drawn for unselected lights.&apos;, &apos;int&apos;: &apos;True&apos;, &apos;name&apos;: &apos;hideHandle&apos;, &apos;widget&apos;: &apos;boolean&apos;}"/>
                  </group_parameter>
                </group_parameter>
              </group_parameter>
            </group_parameter>
          </group_parameter>
        </group_parameter>
      </node>
    </node>
  </node>
</katana>
