  <node name="__SAVE_exportedNodes" type="Group">
    <node autorenameallowed="false" baseType="Group" edited="true" eyepointx="145.875" eyepointy="21.625" eyepointz="10000.0" modTime="1216260096" name="PruneByVolume" ns_basicDisplay="1.0" ns_bubbleZoom="0.0" ns_errorGlow="0.0" ns_fromContext="legacy" ns_iconName="" selected="true" type="Group" viewed="true" viewscalex="1.0" viewscaley="1.0" viewscalez="1.0" x="845.184" y="-891.256">
      <port name="i0" source="Prune_fuzz_and_fog.out" type="in"/>
      <port name="o0" type="out"/>
      <group_parameter name="PruneByVolume">
        <group_parameter hints="{&apos;hideTitle&apos;: &apos;True&apos;}" name="user">
          <string_parameter hints="{&apos;widget&apos;: &apos;scenegraphLocation&apos;}" name="searchUnder" value="/root/world/geo"/>
          <number_parameter hints="{&apos;options__order&apos;: [&apos;inside&apos;, &apos;outside&apos;], &apos;widget&apos;: &apos;mapper&apos;, &apos;options&apos;: {&apos;inside&apos;: 1.0, &apos;outside&apos;: 0.0}}" name="insideOrOutsideTheBox" value="1"/>
          <number_parameter hints="{&apos;options__order&apos;: [&apos;intersection&apos;, &apos;containment&apos;], &apos;widget&apos;: &apos;mapper&apos;, &apos;options&apos;: {&apos;intersection&apos;: 0.0, &apos;containment&apos;: 1.0}}" name="mode" value="0"/>
          <number_parameter hints="{&apos;help&apos;: &apos;&lt;p&gt;volume in cubic units (i.e. centimenters cubed).\n&lt;p&gt;1 cubic centimeter == 1\n&lt;p&gt;1 cubic meter ==  1.0e+06\n&lt;p&gt;5 cubic meters == 1.25e+08&apos;}" name="max_volume" value="1000000"/>
          <number_parameter hints="{&apos;options__order&apos;: [&apos;less than volume&apos;, &apos;more than volume&apos;], &apos;widget&apos;: &apos;mapper&apos;, &apos;options&apos;: {&apos;less than volume&apos;: 0.0, &apos;more than volume&apos;: 1.0}}" name="volume_mode" value="0"/>
          <number_parameter hints="{&apos;widget&apos;: &apos;checkBox&apos;}" name="display_label" value="0"/>
          <string_parameter hints="{&apos;widget&apos;: &apos;scriptButton&apos;, &apos;buttonText&apos;: &apos;Find Components&apos;, &apos;scriptText&apos;: &quot;import Nodes3DAPI, NodegraphAPI\nimport GeoAPI.Util.Matrix as Matrix\nimport time, sys\nfrom functools import reduce\n\n\n\n# //////////////////////////////////////////////////////////////////////////////\n\ndef GetWorldSpaceAxisAlignedBoundsForProducer(producer):\n    try:\n        nx, px, ny, py, nz, pz = producer.getAttribute(&apos;bound&apos;).getData()\n    except:\n        return None\n    \n    inputPoints = [\n        [nx, ny, nz],\n        [nx, ny, pz],\n        [nx, py, nz],\n        [nx, py, pz],\n        [px, ny, nz],\n        [px, ny, pz],\n        [px, py, nz],\n        [px, py, pz],\n    ]\n    matrix = producer.getFlattenedGlobalXform()\n    \n    for point in inputPoints:\n        Matrix.xformPointByMatrix( point,  matrix )\n    \n    nx = reduce(min, [p[0] for p in inputPoints])\n    px = reduce(max, [p[0] for p in inputPoints])\n    ny = reduce(min, [p[1] for p in inputPoints])\n    py = reduce(max, [p[1] for p in inputPoints])\n    nz = reduce(min, [p[2] for p in inputPoints])\n    pz = reduce(max, [p[2] for p in inputPoints])\n    \n    return nx, px, ny, py, nz, pz\n\n# //////////////////////////////////////////////////////////////////////////////\n\ndef Containment( b2, b1):\n    return ((b1[0] &gt;= b2[0] ) and (b1[1] &lt;= b2[1] )) and \\\n           ((b1[2] &gt;= b2[2] ) and (b1[3] &lt;= b2[3] )) and \\\n           ((b1[4] &gt;= b2[4] ) and (b1[5] &lt;= b2[5] ))\n\ndef IntersectBounds( b1, b2 ):\n    return ((b1[0] &lt;= b2[1] ) and (b1[1] &gt;= b2[0] )) and \\\n           ((b1[2] &lt;= b2[3] ) and (b1[3] &gt;= b2[2] )) and \\\n           ((b1[4] &lt;= b2[5] ) and (b1[5] &gt;= b2[4] ))\n\ndef VolumeTest(b1, volume, volume_mode):\n    xtra = 1.0e-5\n\n    dx = (b1[1] - b1[0]) + xtra\n    dy = (b1[3] - b1[2]) + xtra\n    dz = (b1[5] - b1[4]) + xtra\n\n    mvol = abs(dx * dy * dz)\n\n    if volume_mode == 1:\n        return mvol &gt;= volume\n    else:\n        return mvol &lt;= volume\n\n# //////////////////////////////////////////////////////////////////////////////\n\nclass InterruptException(RuntimeError):\n    pass\n\ndef WalkLocation(producer, bounds, include=True, result=None, progressCallback=None, contain=True, volume=0, volume_mode=0):\n    if result is None:\n        result = []\n    if progressCallback: progressCallback(producer.getName())\n    \n    locationType = producer.getType()\n    \n    if locationType in (&apos;assembly&apos;, &apos;component&apos;):\n        localBounds = GetWorldSpaceAxisAlignedBoundsForProducer(producer)\n        if localBounds:\n            \n            if contain:\n                test = Containment( bounds, localBounds)\n            else:\n                test = IntersectBounds( bounds, localBounds)\n\n            if test:\n                if include:\n                    vtest = VolumeTest(localBounds, volume, volume_mode)\n                    if vtest:\n                        result.append(producer.getFullName())\n            elif not include:\n                vtest = VolumeTest(localBounds, volume, volume_mode)\n                if vtest:\n                    result.append(producer.getFullName())\n    \n\n    if locationType == &apos;component&apos;:\n        return result\n    \n    \n    child = producer.getFirstChild()\n    \n    while child:\n        WalkLocation(child, bounds, include, result, progressCallback, contain, volume, volume_mode)\n        child = child.getNextSibling()\n    \n    \n    return result\n    \n\n# //////////////////////////////////////////////////////////////////////////////\n\n\ng_lastUpdate = time.time()\ng_interruptWidget = None\n\ndef ProgressCallback(location):\n    global g_lastUpdate\n    global g_interruptWidget\n    if not g_interruptWidget:\n        return\n    \n    g_interruptWidget.update( &apos;searching: &apos; + location )\n    \n    if time.time() - g_lastUpdate &gt; 0.05:\n        Utils.EventModule.ProcessAllEvents()\n        g_lastUpdate = time.time()\n\ndef InterruptCallback():\n    raise InterruptException(&apos;interrupted&apos;)\n\n\n# //////////////////////////////////////////////////////////////////////////////\n\nprimitiveNode = None\n#get the producer for child node:\nfor child in node.getChildren():\n    if child.getType() == &apos;PrimitiveCreate&apos;:\n        primitiveNode = child\n        break\n\nif not primitiveNode:\n    sys.exit()\n\n\nboxProducer = Nodes3DAPI.GetGeometryProducer(primitiveNode, NodegraphAPI.GetCurrentTime())\nfindBoxProducer = boxProducer.getProducerByPath(&apos;/root/world/find_box&apos;)\nfindBounds = GetWorldSpaceAxisAlignedBoundsForProducer(findBoxProducer)\n\nsourcePort = node.getReturnPort(&apos;o0&apos;)\n#sourcePort, sourceTime = node.getSourcePort(node.getInputPortByIndex(0), NodegraphAPI.GetCurrentTime())\nsourceProducer = Nodes3DAPI.GetGeometryProducer(sourcePort.getNode(), NodegraphAPI.GetCurrentTime(), sourcePort.getIndex())\nsourceProducer = sourceProducer.getProducerByPath( node.getParameter(&apos;user.searchUnder&apos;).getValue(NodegraphAPI.GetCurrentTime()) )\n\n\n# //////////////////////////////////////////////////////////////////////////////\n\n\ng_interruptWidget = Widgets.ModalProcessInterruptWidget(InterruptCallback)\ng_interruptWidget.setFixedWidth(512)\ng_interruptWidget.show()\nUtils.EventModule.ProcessAllEvents()\n\ntry:\n    result = WalkLocation( sourceProducer,\n            findBounds,\n            include=node.getParameter(&apos;user.insideOrOutsideTheBox&apos;).getValue(0),\n            progressCallback=ProgressCallback,\n            contain=node.getParameter(&apos;user.mode&apos;).getValue(0),\n            volume=node.getParameter(&apos;user.max_volume&apos;).getValue(0),\n            volume_mode=node.getParameter(&apos;user.volume_mode&apos;).getValue(0),\n    )\nexcept InterruptException:\n    g_interruptWidget.close()\n    del g_interruptWidget\n    sys.exit()\n\nnode.getParameter(&apos;user.CEL&apos;).setValue( &apos;(&apos; + &apos; &apos;.join(result) + &apos;)&apos;, 0 )\n\ng_interruptWidget.close()\ndel g_interruptWidget\n\n&quot;}" name="newParameter" value=""/>
          <string_parameter hints="{&apos;widget&apos;: &apos;cel&apos;}" name="CEL" value=""/>
        </group_parameter>
      </group_parameter>
